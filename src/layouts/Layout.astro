---
interface Props {
  title: string;
  lang: 'ko' | 'en';
}

const { title, lang } = Astro.props;
const isKo = lang === 'ko';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <header>
      <nav>
        <a href="#hero" class="logo">KYBee</a>
        <div class="nav-right">
          <div class="nav-links">
            <a href="#about">{isKo ? '소개' : 'About'}</a>
            <a href="#experience">{isKo ? '경력' : 'Experience'}</a>
            <a href="#projects">{isKo ? '프로젝트' : 'Projects'}</a>
            <a href="#skills">{isKo ? '기술' : 'Skills'}</a>
            <a href="#education">{isKo ? '학력' : 'Education'}</a>
          </div>
          <span class="lang-switch">
            {isKo ? <strong>KO</strong> : <a href="/">KO</a>}
            <span class="divider">|</span>
            {isKo ? <a href="/en/">EN</a> : <strong>EN</strong>}
          </span>
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; 2024 Youngbeen Kim</p>
    </footer>

    <script is:inline>
      document.getElementById('theme-toggle').addEventListener('click', function() {
        const html = document.documentElement;
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });
    </script>

    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --font-sans: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        --font-mono: 'JetBrains Mono', ui-monospace, monospace;
      }

      [data-theme="dark"] {
        --bg: #0e0e11;
        --bg-card: #17171c;
        --border: #26262c;
        --text: #f4f4f5;
        --text-secondary: #a1a1aa;
        --text-muted: #71717a;
        --accent: #a78bfa;
        --accent-dim: rgba(167, 139, 250, 0.15);
      }

      [data-theme="light"] {
        --bg: #fafafa;
        --bg-card: #ffffff;
        --border: #e4e4e7;
        --text: #18181b;
        --text-secondary: #52525b;
        --text-muted: #a1a1aa;
        --accent: #7c3aed;
        --accent-dim: rgba(124, 58, 237, 0.1);
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-sans);
        background-color: var(--bg);
        color: var(--text);
        line-height: 1.6;
        transition: background-color 0.15s, color 0.15s;
      }

      a {
        color: var(--accent);
        text-decoration: none;
        transition: opacity 0.15s;
      }

      a:hover {
        opacity: 0.8;
      }

      header {
        position: sticky;
        top: 0;
        background: var(--bg);
        border-bottom: 1px solid var(--border);
        z-index: 100;
        transition: background-color 0.15s, border-color 0.15s;
      }

      nav {
        max-width: 900px;
        margin: 0 auto;
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        font-family: var(--font-mono);
        font-weight: 600;
        font-size: 1.1rem;
        color: var(--text);
      }

      .nav-right {
        display: flex;
        gap: 1.5rem;
        align-items: center;
      }

      .nav-links {
        display: flex;
        gap: 1.25rem;
        align-items: center;
      }

      .nav-links a {
        color: var(--text-secondary);
        font-size: 0.9rem;
      }

      .nav-links a:hover {
        color: var(--text);
      }

      .lang-switch {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        color: var(--text-muted);
      }

      .lang-switch strong {
        color: var(--accent);
      }

      .lang-switch .divider {
        color: var(--border);
      }

      .theme-toggle {
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 0.4rem;
        cursor: pointer;
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: border-color 0.15s, color 0.15s;
      }

      .theme-toggle:hover {
        border-color: var(--text-muted);
        color: var(--text);
      }

      [data-theme="dark"] .icon-sun { display: block; }
      [data-theme="dark"] .icon-moon { display: none; }
      [data-theme="light"] .icon-sun { display: none; }
      [data-theme="light"] .icon-moon { display: block; }

      main {
        max-width: 900px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
      }

      section {
        margin-bottom: 5rem;
      }

      #hero {
        padding: 3rem 0 4rem;
        position: relative;
      }

      #hero::before {
        content: '';
        position: absolute;
        top: -100px;
        left: -200px;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
        opacity: 0.06;
        pointer-events: none;
        z-index: -1;
      }

      h1 {
        font-size: 2.75rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
      }

      h2 {
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        color: var(--text);
      }

      h3 {
        font-size: 1.15rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
      }

      h4 {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.25rem;
      }

      p {
        margin-bottom: 0.75rem;
      }

      ul {
        margin-left: 1.25rem;
        margin-bottom: 0.75rem;
      }

      li {
        margin-bottom: 0.4rem;
        color: var(--text-secondary);
      }

      .subtitle {
        font-size: 1.15rem;
        color: var(--accent);
        margin-bottom: 0.75rem;
      }

      .tagline {
        font-size: 1.1rem;
        color: var(--text-secondary);
        margin-bottom: 1rem;
        max-width: 600px;
      }

      .location {
        color: var(--text-muted);
        font-size: 0.9rem;
      }

      .links {
        display: flex;
        gap: 1.25rem;
        flex-wrap: wrap;
        margin-top: 1.25rem;
      }

      .links a {
        color: var(--text-secondary);
        font-size: 0.9rem;
        padding: 0.4rem 0.75rem;
        border: 1px solid var(--border);
        border-radius: 6px;
        transition: border-color 0.15s, color 0.15s;
      }

      .links a:hover {
        border-color: var(--accent);
        color: var(--accent);
        opacity: 1;
      }

      .about-list {
        list-style: none;
        margin-left: 0;
      }

      .about-list li {
        padding-left: 1.25rem;
        position: relative;
        margin-bottom: 0.6rem;
        color: var(--text-secondary);
      }

      .about-list li::before {
        content: '→';
        position: absolute;
        left: 0;
        color: var(--accent);
      }

      /* Timeline */
      .timeline {
        position: relative;
        padding-left: 2rem;
      }

      .timeline::before {
        content: '';
        position: absolute;
        left: 0.35rem;
        top: 0.5rem;
        bottom: 0.5rem;
        width: 2px;
        background: var(--border);
      }

      .timeline-item {
        position: relative;
        margin-bottom: 2.5rem;
      }

      .timeline-item::before {
        content: '';
        position: absolute;
        left: -1.65rem;
        top: 0.35rem;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--accent);
        border: 2px solid var(--bg);
      }

      .timeline-item:last-child {
        margin-bottom: 0;
      }

      .project-title {
        font-weight: 600;
        margin-bottom: 0.25rem;
      }

      .project-summary {
        color: var(--text-muted);
        font-size: 0.9rem;
        margin-bottom: 0.75rem;
      }

      .project-bullets {
        list-style: disc;
        margin-left: 1.25rem;
        margin-bottom: 0.75rem;
      }

      .project-bullets li {
        color: var(--text-secondary);
        font-size: 0.95rem;
        margin-bottom: 0.35rem;
      }

      .highlight {
        color: var(--accent);
        font-weight: 600;
      }

      .tech-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 0.5rem;
      }

      .tech-tags code {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--accent);
        background: transparent;
        border: 1px solid var(--accent);
        padding: 0.15rem 0.5rem;
        border-radius: 9999px;
        opacity: 0.85;
      }

      .job {
        margin-bottom: 2.5rem;
      }

      .job-header {
        margin-bottom: 1rem;
      }

      .job-period {
        color: var(--text-muted);
        font-size: 0.9rem;
      }

      .intern-list {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
      }

      .intern-item {
        margin-bottom: 1rem;
      }

      .intern-item h4 {
        font-size: 0.95rem;
        color: var(--text);
      }

      .intern-item p {
        color: var(--text-muted);
        font-size: 0.85rem;
        margin-bottom: 0.25rem;
      }

      .side-project-list {
        list-style: none;
        margin: 0;
      }

      .side-project-list li {
        padding: 1rem;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 8px;
        margin-bottom: 0.75rem;
        transition: border-color 0.15s;
      }

      .side-project-list li:hover {
        border-color: var(--accent);
      }

      .project-name {
        font-weight: 600;
        color: var(--text);
      }

      .project-name a {
        color: var(--text);
      }

      .project-name a:hover {
        color: var(--accent);
      }

      .project-tech {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--accent);
        margin-left: 0.5rem;
      }

      .project-desc {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-top: 0.25rem;
      }

      .badge {
        display: inline-block;
        background: var(--accent-dim);
        color: var(--accent);
        font-size: 0.75rem;
        font-weight: 500;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        margin-left: 0.5rem;
      }

      .activities {
        color: var(--text-muted);
        font-size: 0.9rem;
        margin-top: 1rem;
      }

      .skills-grid {
        display: grid;
        gap: 0.6rem;
      }

      .skill-row {
        display: flex;
        gap: 1rem;
        align-items: baseline;
      }

      .skill-label {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--accent);
        min-width: 110px;
      }

      .skill-value {
        color: var(--text-secondary);
        font-size: 0.95rem;
      }

      .edu-section {
        margin-bottom: 2rem;
      }

      .edu-section h3 {
        font-size: 1rem;
        color: var(--text);
        margin-bottom: 0.5rem;
      }

      .edu-detail {
        color: var(--text-secondary);
        font-size: 0.95rem;
      }

      .edu-courses {
        color: var(--text-muted);
        font-size: 0.85rem;
        margin-top: 0.35rem;
      }

      .cert-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .cert-item {
        font-size: 0.85rem;
        color: var(--text-secondary);
        padding: 0.3rem 0.6rem;
        border: 1px solid var(--border);
        border-radius: 4px;
      }

      .languages {
        color: var(--text-muted);
        font-size: 0.9rem;
        margin-top: 1.5rem;
      }

      footer {
        text-align: center;
        padding: 2rem;
        color: var(--text-muted);
        font-size: 0.85rem;
        border-top: 1px solid var(--border);
      }

      @media (max-width: 700px) {
        .nav-links {
          display: none;
        }

        h1 {
          font-size: 2rem;
        }

        .timeline {
          padding-left: 1.5rem;
        }

        .timeline-item::before {
          left: -1.15rem;
        }

        .skill-row {
          flex-direction: column;
          gap: 0.25rem;
        }

        .skill-label {
          min-width: auto;
        }
      }
    </style>
  </body>
</html>
