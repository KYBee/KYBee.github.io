  }

  .links {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-2);
  }

  .links a {
    color: var(--text-secondary);
    font-size: var(--fs-base);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--border);
