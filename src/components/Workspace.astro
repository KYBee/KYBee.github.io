    }

    .avatar {
      width: 32px;
      height: 32px;
      font-size: var(--fs-xs);
    }

    .message {
      flex-direction: column;
      gap: var(--space-2);
    }

    .reactions {
      row-gap: var(--space-1);
    }

    .profile-panel {
      width: 100%;
    }

    .profile-body {
      padding: 0 var(--space-4) var(--space-4);
    }

    .profile-header {
      justify-content: flex-start;
      gap: var(--space-3);
      padding: var(--space-3) var(--space-2);
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      background: var(--bg);
      z-index: 2;
    }

    .profile-back {
      display: flex;
      background: transparent;
      border: none;
      color: var(--text);
      cursor: pointer;
      padding: var(--space-2);
    }

    .profile-header-title {
      display: block;
      font-weight: 700;
      font-size: var(--fs-md);
    }

    .profile-close {
      display: none;
    }
  }
</style>

<script>
  const themeToggles = document.querySelectorAll<HTMLButtonElement>('.theme-toggle');
  themeToggles.forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const html = document.documentElement;
      const current = html.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
    });
  });

  const hamburger = document.getElementById('hamburger');
  const drawer = document.getElementById('drawer');
  const drawerBackdrop = document.getElementById('drawer-backdrop');
  const drawerClose = document.getElementById('drawer-close');

  const openDrawer = () => {
    drawer?.classList.add('is-open');
    drawerBackdrop?.classList.add('is-open');
    drawer?.setAttribute('aria-hidden', 'false');
    drawer?.removeAttribute('inert');
    hamburger?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };

  const closeDrawer = () => {
    drawer?.classList.remove('is-open');
    drawerBackdrop?.classList.remove('is-open');
    drawer?.setAttribute('aria-hidden', 'true');
    drawer?.setAttribute('inert', '');
    hamburger?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  hamburger?.addEventListener('click', openDrawer);
  drawerClose?.addEventListener('click', closeDrawer);
  drawerBackdrop?.addEventListener('click', closeDrawer);
  drawer?.querySelectorAll('a, [data-open-profile]').forEach((el) => el.addEventListener('click', closeDrawer));

  const navLinks = document.querySelectorAll<HTMLElement>('[data-channel-link]');
  const sections = document.querySelectorAll<HTMLElement>('.channel');

  const setActive = (id: string) => {
    navLinks.forEach((link) => {
      link.classList.toggle('is-active', link.dataset.channelLink === id);
    });
  };

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
        }
      });
    },
    { rootMargin: '-40% 0px -55% 0px', threshold: 0 }
  );

  sections.forEach((section) => observer.observe(section));

  /* ---------- Profile panel ---------- */
  const profileTriggers = document.querySelectorAll<HTMLElement>('[data-open-profile]');
  const profilePanel = document.getElementById('profile-panel');
  const profileBackdrop = document.getElementById('profile-backdrop');
  const profileClose = document.getElementById('profile-close');
  const profileBack = document.getElementById('profile-back');
  let lastFocused: HTMLElement | null = null;

  const isVisible = (el: HTMLElement | null): el is HTMLElement => !!el && el.offsetParent !== null;

  const openProfile = (trigger?: HTMLElement) => {
    lastFocused = trigger ?? (document.activeElement as HTMLElement);
    profilePanel?.classList.add('is-open');
    profileBackdrop?.classList.add('is-open');
    profilePanel?.setAttribute('aria-hidden', 'false');
    profilePanel?.removeAttribute('inert');
    document.body.style.overflow = 'hidden';
    profileTriggers.forEach((el) => el.classList.add('is-active'));
    [profileBack, profileClose].find(isVisible)?.focus();
  };

  const closeProfile = () => {
    if (!profilePanel?.classList.contains('is-open')) return;
    profilePanel?.classList.remove('is-open');
    profileBackdrop?.classList.remove('is-open');
    profilePanel?.setAttribute('aria-hidden', 'true');
    profilePanel?.setAttribute('inert', '');
    document.body.style.overflow = '';
    profileTriggers.forEach((el) => el.classList.remove('is-active'));
    lastFocused?.focus();
    lastFocused = null;
  };

  profileTriggers.forEach((el) => el.addEventListener('click', () => openProfile(el)));
  profileClose?.addEventListener('click', closeProfile);
  profileBack?.addEventListener('click', closeProfile);
  profileBackdrop?.addEventListener('click', closeProfile);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeDrawer();
      closeProfile();
    }
    if (e.key === 'Tab' && profilePanel?.classList.contains('is-open')) {
      const focusable = Array.from(
        profilePanel.querySelectorAll<HTMLElement>('a[href], button:not([disabled])')
      ).filter(isVisible);
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });

  const content = document.querySelector<HTMLElement>('.content');
  const profileLabel = content?.dataset.profileLabel ?? '';
  content?.querySelectorAll<HTMLElement>('.avatar, .message-author').forEach((el) => {
    el.setAttribute('tabindex', '0');
    el.setAttribute('role', 'button');
    if (profileLabel) el.setAttribute('aria-label', profileLabel);
  });

  content?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('.avatar, .message-author')) openProfile();
  });

  content?.addEventListener('keydown', (e) => {
    const key = (e as KeyboardEvent).key;
    if ((key === 'Enter' || key === ' ') && (e.target as HTMLElement).closest('.avatar, .message-author')) {
      e.preventDefault();
      openProfile();
    }
  });
</script>

