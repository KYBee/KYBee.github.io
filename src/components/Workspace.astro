---
import { getCollection, type CollectionEntry } from 'astro:content';
import Avatar from './Avatar.astro';

interface Props {
  lang: 'ko' | 'en';
}

const { lang } = Astro.props;

const byLang = <T extends { data: { lang: string } }>(entry: T) => entry.data.lang === lang;
const byOrder = (a: { data: { order?: number } }, b: { data: { order?: number } }) =>
  (a.data.order ?? 0) - (b.data.order ?? 0);

const [aboutEntries, projectEntries, sideProjectEntries, educationEntries, certEntries, skillEntries] =
  await Promise.all([
    getCollection('about', byLang),
    getCollection('projects', byLang),
    getCollection('sideProjects', byLang),
    getCollection('education', byLang),
    getCollection('certifications', byLang),
    getCollection('skills', byLang),
  ]);

const about = aboutEntries[0].data;
const projects = [...projectEntries].sort(byOrder).map((e) => e.data);
const sideProjects = [...sideProjectEntries].sort(byOrder).map((e) => e.data);
const education = [...educationEntries].sort(byOrder).map((e) => e.data)[0];
const certifications = [...certEntries].sort(byOrder).map((e) => e.data);
const skills = [...skillEntries].sort(byOrder).map((e) => e.data);

type ProjectData = CollectionEntry<'projects'>['data'];
type ProjectGroup = { company: string; role: string; period: string; location?: string; items: ProjectData[] };

const projectGroups: ProjectGroup[] = [];
for (const p of projects) {
  const last = projectGroups[projectGroups.length - 1];
  if (last && last.company === p.company && last.role === p.role && last.period === p.period) {
    last.items.push(p);
  } else {
    projectGroups.push({ company: p.company, role: p.role, period: p.period, location: p.location, items: [p] });
  }
}

const firstJob = projects[0];
const samsungItems = projectGroups[0]?.items ?? [];

const reactionSets: [string, string][][] = [
  [['🔥', '5'], ['👍', '2']],
  [['🎉', '3'], ['💯', '1']],
  [['🚀', '4'], ['👏', '2']],
  [['✅', '3'], ['👍', '1']],
];

const initials = 'YB';

const displayUrl = (url: string) => url.replace(/^https?:\/\//, '').replace(/^www\./, '').replace(/\/$/, '');

const copy = {
  ko: {
    channelsLabel: '채널',
    dmLabel: '다이렉트 메시지',
    channels: {
      experience: '경력',
      'work-projects': '업무-프로젝트',
      'side-projects': '사이드-프로젝트',
      skills: '기술',
      education: '학력-자격',
    },
    topics: {
      experience: firstJob ? `${firstJob.company} ${firstJob.role} · ${firstJob.period}` : '',
      'side-projects': '사이드 프로젝트 & 활동',
      skills: '사용 기술 스택',
      education: education ? `${education.school} · ${education.detail}` : '',
    },
    previews: {
      experience: projectGroups.map((g) => g.company).join(' · '),
      'work-projects': samsungItems.slice(0, 2).map((p) => p.title).join(' · '),
      'side-projects': sideProjects.slice(0, 2).map((p) => p.name).join(' · '),
      skills: skills.map((s) => s.category).join(' · '),
      education: education?.detail ?? '',
    },
    workProjectsContext: firstJob ? `${firstJob.company} 재직 중 수행 · ${firstJob.period}` : '',
    me: `${about.name} (나)`,
    hamburgerLabel: '메뉴 열기',
    closeLabel: '닫기',
    themeLabel: '테마 전환',
    also: '그 외',
    certifications: '자격증 & 어학',
    profileOpenLabel: `${about.name} 프로필 보기`,
    profileTitle: '프로필',
    backLabel: '뒤로가기',
    contactInfoTitle: '연락처 정보',
    emailLabel: '이메일',
    aboutMeTitle: '내 소개',
    fieldLabels: {
      affiliation: '소속',
      work: '하는 일',
      interests: '요즘 관심사',
      strengths: '잘하는 것',
      communities: '커뮤니티',
      whereabouts: '출몰지역',
    },
  },
  en: {
    channelsLabel: 'Channels',
    dmLabel: 'Direct Messages',
    channels: {
      experience: 'experience',
      'work-projects': 'work-projects',
      'side-projects': 'side-projects',
      skills: 'skills',
      education: 'education',
    },
    topics: {
      experience: firstJob ? `${firstJob.company} ${firstJob.role} · ${firstJob.period}` : '',
      'side-projects': 'Side projects & activities',
      skills: 'Tech stack',
      education: education ? `${education.school} · ${education.detail}` : '',
    },
    previews: {
      experience: projectGroups.map((g) => g.company).join(' · '),
      'work-projects': samsungItems.slice(0, 2).map((p) => p.title).join(' · '),
      'side-projects': sideProjects.slice(0, 2).map((p) => p.name).join(' · '),
      skills: skills.map((s) => s.category).join(' · '),
      education: education?.detail ?? '',
    },
    workProjectsContext: firstJob ? `Completed while at ${firstJob.company} · ${firstJob.period}` : '',
    me: `${about.name} (you)`,
    hamburgerLabel: 'Open menu',
    closeLabel: 'Close',
    themeLabel: 'Toggle theme',
    also: 'Also',
    certifications: 'Certifications & Languages',
    profileOpenLabel: `View ${about.name}'s profile`,
    profileTitle: 'Profile',
    backLabel: 'Back',
    contactInfoTitle: 'Contact information',
    emailLabel: 'Email',
    aboutMeTitle: 'About me',
    fieldLabels: {
      affiliation: 'Team',
      work: 'What I do',
      interests: 'Into these days',
      strengths: 'Good at',
      communities: 'Communities',
      whereabouts: 'Usually found in',
    },
  },
} as const;

const t = copy[lang];
const channelOrder = ['experience', 'work-projects', 'side-projects', 'skills', 'education'] as const;
---

<div class="workspace">
  <header class="topbar">
    <button id="hamburger" class="hamburger" aria-label={t.hamburgerLabel} aria-expanded="false" aria-controls="drawer">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    <span class="topbar-title">KYBee</span>
    <button class="theme-toggle" aria-label={t.themeLabel}>
      <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
      <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
    </button>
  </header>

  <div class="drawer-backdrop" id="drawer-backdrop"></div>
  <nav class="drawer" id="drawer" aria-hidden="true" inert>
    <div class="drawer-header">
      <span class="workspace-name">KYBee</span>
      <button class="drawer-close" id="drawer-close" aria-label={t.closeLabel}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    <p class="nav-group-label">{t.channelsLabel}</p>
    <ul class="drawer-channel-list">
      {channelOrder.map((key) => (
        <li>
          <a href={`#${key}`} class="drawer-channel-link" data-channel-link={key}>
            <span class="drawer-channel-name"># {t.channels[key]}</span>
            <span class="drawer-preview">{t.previews[key]}</span>
          </a>
        </li>
      ))}
    </ul>
    <p class="nav-group-label">{t.dmLabel}</p>
    <button type="button" class="drawer-dm" data-open-profile aria-haspopup="dialog">
      <span class="dm-avatar">
        <Avatar initials={initials} size={22} radius="var(--radius-sm)" fontSize="0.65rem" />
        <span class="status-dot" aria-hidden="true"></span>
      </span>
      {t.me}
    </button>
    <div class="drawer-footer">
      <span class="lang-switch">
        {lang === 'ko' ? <strong>KO</strong> : <a href="/">KO</a>}
        <span class="divider">|</span>
        {lang === 'ko' ? <a href="/en/">EN</a> : <strong>EN</strong>}
      </span>
    </div>
  </nav>

  <aside class="sidebar">
    <div class="sidebar-header">
      <span class="workspace-name">KYBee</span>
      <div class="sidebar-header-actions">
        <span class="lang-switch">
          {lang === 'ko' ? <strong>KO</strong> : <a href="/">KO</a>}
          <span class="divider">|</span>
          {lang === 'ko' ? <a href="/en/">EN</a> : <strong>EN</strong>}
        </span>
        <button class="theme-toggle" aria-label={t.themeLabel}>
          <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
          <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
        </button>
      </div>
    </div>

    <nav class="channel-nav" aria-label={t.channelsLabel}>
      <p class="nav-group-label">{t.channelsLabel}</p>
      <ul class="channel-list">
        {channelOrder.map((key) => (
          <li>
            <a href={`#${key}`} class="channel-link" data-channel-link={key}># {t.channels[key]}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="dm-section">
      <p class="nav-group-label">{t.dmLabel}</p>
      <button type="button" class="dm-item" data-open-profile aria-haspopup="dialog">
        <span class="dm-avatar">
          <Avatar initials={initials} size={22} radius="var(--radius-sm)" fontSize="0.65rem" />
          <span class="status-dot" aria-hidden="true"></span>
        </span>
        {t.me}
      </button>
    </div>
  </aside>

  <main class="content" data-profile-label={t.profileOpenLabel}>
    <div class="channel-intro">
      <div class="channel-intro-avatar" aria-hidden="true">
        <Avatar initials={initials} size={72} radius="var(--radius-lg)" fontSize="1.5rem" />
      </div>
      <div class="channel-intro-heading">
        <p class="channel-intro-name">{about.name}</p>
        <p class="channel-intro-title">{about.title}</p>
      </div>
      <div class="channel-intro-status">
        <span class="status-dot" aria-hidden="true"></span>
        {about.activityStatus}
      </div>
      <div class="channel-intro-links">
        <a class="channel-intro-link" href={about.links.github} target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path></svg>
          <span>GitHub</span>
        </a>
        <a class="channel-intro-link" href={about.links.blog} target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
          <span>Blog</span>
        </a>
        <a class="channel-intro-link" href={about.links.linkedin} target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
          <span>LinkedIn</span>
        </a>
        <a class="channel-intro-link" href={`mailto:${about.links.email}`}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"></rect><polyline points="22,6 12,13 2,6"></polyline></svg>
          <span>Email</span>
        </a>
      </div>
      <ul class="channel-intro-bullets">
        {about.bullets.map((bullet) => <li>{bullet}</li>)}
      </ul>
    </div>

    <section id="experience" class="channel">
      <header class="channel-header">
        <h1># {t.channels.experience}</h1>
        <p class="channel-topic">{t.topics.experience}</p>
      </header>
      <div class="message">
        <div class="avatar"><Avatar initials={initials} size={44} /></div>
        <div class="message-body">
          <div class="message-meta">
            <span class="message-author">{about.name}</span>
          </div>
          {projectGroups.map((group, gi) => (
            <>
              {gi > 0 && <hr class="job-hr" />}
              <div class="job-group">
                <p class="job-divider">
                  {group.company} — {group.role} · {group.period}{group.location ? ` · ${group.location}` : ''}
                </p>
                {gi === 0 ? (
                  <p class="message-summary">{about.work}</p>
                ) : (
                  group.items.map((item) => (
                    <>
                      {item.summary && <p class="message-summary">{item.summary}</p>}
                      {item.tags.length > 0 && (
                        <div class="reactions">
                          {item.tags.map((tag) => (
                            <span class="tag-pill">{tag}</span>
                          ))}
                        </div>
                      )}
                    </>
                  ))
                )}
              </div>
            </>
          ))}
        </div>
      </div>
    </section>

    <section id="work-projects" class="channel">
      <header class="channel-header">
        <h1># {t.channels['work-projects']}</h1>
        <p class="channel-topic">{t.workProjectsContext}</p>
      </header>
      {samsungItems.map((item, i) => (
        <div class="message">
          <div class="avatar"><Avatar initials={initials} size={44} /></div>
          <div class="message-body">
            <div class="message-meta">
              <span class="message-author">{about.name}</span>
              <span class="message-time">{item.company} · {item.period}</span>
            </div>
            {item.title && <p class="message-title">{item.title}</p>}
            {item.summary && <p class="message-summary">{item.summary}</p>}
            {item.bullets && (
              <ul class="message-bullets">
                {item.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            )}
            {item.metric && <blockquote class="quote-block">{item.metric}</blockquote>}
            {(item.tags.length > 0 || item.metric) && (
              <div class="reactions">
                {item.metric &&
                  reactionSets[i % reactionSets.length].map(([emoji, count]) => (
                    <span class="reaction-pill">
                      {emoji} {count}
                    </span>
                  ))}
                {item.tags.map((tag) => (
                  <span class="tag-pill">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </section>

    <section id="side-projects" class="channel">
      <header class="channel-header">
        <h1># {t.channels['side-projects']}</h1>
        <p class="channel-topic">{t.topics['side-projects']}</p>
      </header>
      {sideProjects.map((project, i) => (
        <div class="message">
          <div class="avatar"><Avatar initials={initials} size={44} /></div>
          <div class="message-body">
            <div class="message-meta">
              <span class="message-author">{about.name}</span>
            </div>
            <p class="message-title">
              {project.url ? <a href={project.url} target="_blank" rel="noopener">{project.name}</a> : project.name}
            </p>
            <p class="message-summary">{project.description}</p>
            <div class="reactions">
              <span class="reaction-pill">{reactionSets[i % reactionSets.length][0][0]} {reactionSets[i % reactionSets.length][0][1]}</span>
              <span class="tag-pill">{project.tech}</span>
              {project.badge && <span class="badge-pill">{project.badge}</span>}
            </div>
          </div>
        </div>
      ))}
      <p class="channel-footnote">{about.activities}</p>
    </section>

    <section id="skills" class="channel">
      <header class="channel-header">
        <h1># {t.channels.skills}</h1>
        <p class="channel-topic">{t.topics.skills}</p>
      </header>
      <div class="message">
        <div class="avatar"><Avatar initials={initials} size={44} /></div>
        <div class="message-body">
          <div class="message-meta">
            <span class="message-author">{about.name}</span>
          </div>
          {skills.map((group) => (
            <div class="skill-group">
              <p class="skill-category">{group.category}</p>
              <div class="reactions">
                {group.items.map((item) => (
                  <span class="tag-pill">{item}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="education" class="channel">
      <header class="channel-header">
        <h1># {t.channels.education}</h1>
        <p class="channel-topic">{t.topics.education}</p>
      </header>
      {education && (
        <div class="message">
          <div class="avatar"><Avatar initials={initials} size={44} /></div>
          <div class="message-body">
            <div class="message-meta">
              <span class="message-author">{about.name}</span>
              <span class="message-time">{education.period}</span>
            </div>
            <p class="message-title">{education.school}</p>
            <p class="message-summary">{education.department}</p>
            <blockquote class="quote-block">{education.detail}</blockquote>
            {education.courses && (
              <ul class="message-bullets">
                {education.courses.map((c) => (
                  <li>
                    <strong>{c.category}:</strong> {c.items.join(', ')}
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      )}
      <div class="message">
        <div class="avatar"><Avatar initials={initials} size={44} /></div>
        <div class="message-body">
          <div class="message-meta">
            <span class="message-author">{about.name}</span>
            <span class="message-time">{t.certifications}</span>
          </div>
          <div class="reactions">
            {certifications.map((cert) => (
              <span class="tag-pill">{cert.name}{cert.date ? ` · ${cert.date}` : ''}</span>
            ))}
          </div>
          {education?.languages && <p class="message-summary">{education.languages}</p>}
        </div>
      </div>
    </section>

  </main>

  <div class="profile-backdrop" id="profile-backdrop"></div>
  <aside
    class="profile-panel"
    id="profile-panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="profile-name"
    aria-hidden="true"
    inert
  >
    <div class="profile-header">
      <button class="profile-back" id="profile-back" aria-label={t.backLabel}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
      </button>
      <span class="profile-header-title">{t.profileTitle}</span>
      <button class="profile-close" id="profile-close" aria-label={t.closeLabel}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    <div class="profile-body">
